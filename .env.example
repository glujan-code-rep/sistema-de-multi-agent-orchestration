# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Options: lmstudio, openai, gemini
LLM_PROVIDER=lmstudio

# LM Studio (Local LLM)
LM_STUDIO_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=gemma-4-26b-a4b-it

# OpenAI (Cloud LLM) - Optional
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini (Cloud LLM) - Optional
# GOOGLE_API_KEY=your-gemini-api-key-here

# =============================================================================
# Langfuse Configuration (Workflow Tracing)
# =============================================================================
# Get your keys from https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# LangSmith Configuration (Auto-tracing for LangChain)
# =============================================================================
# Enable LangChain auto-tracing (LANGSMITH_TRACING_V2 is deprecated, use LANGCHAIN_TRACING)
LANGCHAIN_TRACING=true
LANGCHAIN_TRACING_V2=true
# Get your key from https://smith.langchain.com/settings
LANGSMITH_API_KEY=ls_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Project name in LangSmith dashboard
LANGSMITH_PROJECT=multi-agent-support

# =============================================================================
# Embedding Model Configuration
# =============================================================================
# Options: sentence-transformers (local), openai (cloud)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# Security Configuration
# =============================================================================
ENABLE_CONTENT_MODERATION=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
DEBUG_MODE=false